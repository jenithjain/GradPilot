                  <Star className="h-3.5 w-3.5 text-violet-300" />
                  <span className="text-xs text-violet-300">{topPickLabel}</span>
                </div>
              </div>
            </div>

            {/* Wellbeing */}
            <div
              ref={ref(2)}
              className="rounded-2xl p-6"
              style={{
                background: "linear-gradient(135deg, rgba(5,78,59,0.30) 0%, rgba(6,46,36,0.24) 50%, rgba(7,28,58,0.30) 100%)",
                border: "1px solid rgba(16,185,129,0.24)",
              }}
            >
              <div className="mb-5 flex items-center gap-3">
                <div className="flex h-9 w-9 items-center justify-center rounded-xl" style={{ background: "rgba(16,185,129,0.22)" }}>
                  <Activity className="h-5 w-5 text-emerald-400" />
                </div>
                <div>
                  <p className="text-sm font-bold text-white/70">Wellbeing Scores</p>
                  <p className="text-xs font-medium uppercase tracking-widest text-white/25">AI-assessed today</p>
                </div>
              </div>

              <div className="flex items-center justify-around py-2">
                <RadialScore value={72} label="Focus"      color="#60a5fa" delay={0.55} />
                <RadialScore value={58} label="Confidence" color="#a78bfa" delay={0.70} />
                <RadialScore value={44} label="Stress"     color="#34d399" delay={0.85} />
              </div>

              <div className="mt-5 rounded-xl px-4 py-3"
                style={{ background: "rgba(16,185,129,0.10)", border: "1px solid rgba(16,185,129,0.14)" }}>
                <p className="text-xs text-white/30">AI Assessment</p>
                <p className="mt-1.5 text-sm leading-relaxed text-white/55">
                  Focus is high -- ideal for tackling complex applications. Stress is manageable; maintain your momentum.
                </p>
              </div>
            </div>
          </div>

          {/* Recommendations */}
          <div ref={ref(3)}>
            <div className="mb-5 flex items-center justify-between">
              <div>
                <h2 className="text-xl font-black text-white">Personalised Recommendations</h2>
                <p className="text-sm text-white/35">Curated for your profile &middot; Updated today</p>
              </div>
              <span className="rounded-full px-3 py-1 text-xs font-bold text-emerald-400"
                style={{ background: "rgba(16,185,129,0.14)", border: "1px solid rgba(16,185,129,0.24)" }}>
                3 New
              </span>
            </div>

            <div className="grid grid-cols-1 gap-4 sm:grid-cols-3">
              {recommendations.map((rec) => (
                <div
                  key={rec.id}
                  className="group relative cursor-pointer overflow-hidden rounded-2xl p-6 transition-all duration-300 hover:scale-[1.02] hover:brightness-110"
                  style={rec.cardStyle}
                >
                  <div className="mb-4 flex items-start justify-between">
                    <div className={`flex h-11 w-11 items-center justify-center rounded-xl ${rec.iconBg}`}>
                      <rec.icon className={`h-5 w-5 ${rec.iconCls}`} />
                    </div>
                    <span className={`rounded-full px-2.5 py-0.5 text-xs font-bold ${rec.tagClass}`}>{rec.tag}</span>
                  </div>
                  <h3 className="text-base font-black text-white">{rec.title}</h3>
                  <p className="mt-1.5 text-sm text-white/45">{rec.desc}</p>
                  <button className="mt-5 flex items-center gap-1 text-sm font-bold text-white/50 transition-colors group-hover:text-white">
                    {rec.cta}
                    <ChevronRight className="h-3.5 w-3.5 transition-transform group-hover:translate-x-1" />
                  </button>
                </div>
              ))}
            </div>
          </div>

          {/* Journey Path */}
          <JourneyPath
            avatar={avatar}
            avatarAccent={avatarAccent}
            readinessScore={readinessScore}
            data={data}
          />

          {/* Voice + Follow-Up */}
          <div className="grid grid-cols-1 gap-6 lg:grid-cols-2">

            {/* Voice */}
            <div
              ref={ref(4)}
              className="rounded-2xl p-7"
              style={{
                background: "linear-gradient(180deg, rgba(6,182,212,0.12) 0%, rgba(15,23,42,0.72) 100%)",
                border: "1px solid rgba(6,182,212,0.18)",
              }}
            >
              <div className="mb-6 flex items-center gap-2">
                <Mic className="h-4 w-4 text-cyan-400" />
                <span className="text-sm font-bold text-white/60">Voice Interaction</span>
              </div>

              <div className="flex flex-col items-center gap-6 py-2">
                <div className="relative flex items-center justify-center">
                  {isListening && (
                    <>
                      <span className="absolute h-28 w-28 animate-ping rounded-full bg-cyan-500/15 duration-700" />
                      <span className="absolute h-20 w-20 animate-ping rounded-full bg-cyan-500/20" style={{ animationDelay: "0.25s" }} />
                    </>
                  )}
                  <button
                    onClick={handleMic}
                    className={`relative z-10 flex h-[72px] w-[72px] items-center justify-center rounded-full transition-all duration-300 ${isListening ? "scale-110" : "hover:scale-105"}`}
                    style={isListening
                      ? { background: "#06b6d4", boxShadow: "0 0 36px rgba(6,182,212,0.70)" }
                      : { background: "rgba(255,255,255,0.08)" }
                    }
                  >
                    <Mic className={`h-7 w-7 ${isListening ? "text-white" : "text-white/45"}`} />
                  </button>
                </div>

                <Waveform active={isListening} />

                <div className="w-full min-h-[72px] rounded-xl px-5 py-4"
                  style={{ background: "rgba(255,255,255,0.04)", border: "1px solid rgba(255,255,255,0.07)" }}>
                  {aiThinking ? (
                    <div className="flex items-center gap-2.5">
                      <span className="text-sm font-medium text-violet-300">AI Thinking</span>
                      <div className="flex gap-1">
                        {[0, 1, 2].map((i) => (
                          <span key={i} className="h-1.5 w-1.5 rounded-full bg-violet-400 animate-bounce" style={{ animationDelay: `${i * 0.15}s` }} />
                        ))}
                      </div>
                    </div>
                  ) : aiResponse ? (
                    <p className="text-sm leading-relaxed text-white/65">{aiResponse}</p>
                  ) : (
                    <p className="text-sm text-white/20">
                      {isListening ? "Listening... speak your question" : "Tap the mic and ask your counsellor anything"}
                    </p>
                  )}
                </div>
              </div>
            </div>

            {/* Follow-up tracker */}
            <div
              ref={ref(5)}
              className="rounded-2xl p-7"
              style={{
                background: "linear-gradient(180deg, rgba(99,102,241,0.14) 0%, rgba(15,23,42,0.72) 100%)",
                border: "1px solid rgba(99,102,241,0.20)",
              }}
            >
              <div className="mb-6 flex items-center justify-between">
                <div className="flex items-center gap-2">
                  <Calendar className="h-4 w-4 text-indigo-400" />
                  <span className="text-sm font-bold text-white/60">Follow-Up Tracker</span>
                </div>
                <Button
                  size="sm"
                  className="h-8 text-indigo-300 text-xs font-semibold"
                  style={{ background: "rgba(99,102,241,0.20)", border: "1px solid rgba(99,102,241,0.30)" }}
                >
                  Launch Follow-up
                </Button>
              </div>

              <div className="space-y-3">
                {SESSIONS.map((s, i) => (
                  <div key={i} className="flex items-start gap-3 rounded-xl px-4 py-3.5 transition-colors"
                    style={{ background: "rgba(255,255,255,0.04)", border: "1px solid rgba(255,255,255,0.06)" }}
                    onMouseEnter={(e) => { e.currentTarget.style.background = "rgba(255,255,255,0.07)"; }}
                    onMouseLeave={(e) => { e.currentTarget.style.background = "rgba(255,255,255,0.04)"; }}
                  >
                    <div className="relative mt-1 flex flex-col items-center">
                      <div className={`h-3 w-3 rounded-full ${s.color} shadow-[0_0_8px] ${s.glow}`} />
                      {i < SESSIONS.length - 1 && <div className="mt-1.5 h-8 w-px" style={{ background: "rgba(255,255,255,0.08)" }} />}
                    </div>
                    <div className="flex-1 min-w-0">
                      <p className="text-sm font-bold text-white">{s.topic}</p>
                      <p className="mt-0.5 text-xs text-white/35">{s.date} &middot; {s.time}</p>
                    </div>
                    <span className={`mt-0.5 shrink-0 rounded-full px-2.5 py-0.5 text-[10px] font-bold ${
                      s.status === "upcoming"
                        ? "bg-emerald-500/15 text-emerald-400 ring-1 ring-emerald-500/20"
                        : "bg-white/8 text-white/35"
                    }`}>
                      {s.status}
                    </span>
                  </div>
                ))}
              </div>
            </div>
          </div>

          {/* Progress graph */}
          <div
            ref={ref(6)}
            className="rounded-2xl p-7"
            style={{
              background: "linear-gradient(180deg, rgba(20,10,50,0.65) 0%, rgba(7,10,25,0.82) 100%)",
              border: "1px solid rgba(129,140,248,0.20)",
            }}
          >
            <div className="mb-6 flex items-center justify-between">
              <div>
                <h2 className="text-xl font-black text-white">Readiness Trend</h2>
                <p className="text-sm text-white/35">Your improvement over the past 7 months</p>
              </div>
              <div className="flex items-center gap-1.5 rounded-full px-3.5 py-1.5"
                style={{ background: "rgba(16,185,129,0.13)", border: "1px solid rgba(16,185,129,0.24)" }}>
                <TrendingUp className="h-3.5 w-3.5 text-emerald-400" />
                <span className="text-xs font-bold text-emerald-400">+59 pts this period</span>
              </div>
            </div>

            <ResponsiveContainer width="100%" height={260}>
              <AreaChart data={PROGRESS_DATA} margin={{ top: 4, right: 4, left: -22, bottom: 0 }}>
                <defs>
                  <linearGradient id="aiDashAreaGrad" x1="0" y1="0" x2="0" y2="1">
                    <stop offset="0%"   stopColor="#a78bfa" stopOpacity={0.55} />
                    <stop offset="100%" stopColor="#818cf8" stopOpacity={0}    />
                  </linearGradient>
                </defs>
                <CartesianGrid strokeDasharray="3 3" stroke="rgba(255,255,255,0.05)" />
                <XAxis dataKey="month" tick={{ fill: "rgba(255,255,255,0.30)", fontSize: 12 }} axisLine={false} tickLine={false} />
                <YAxis domain={[0, 100]} tick={{ fill: "rgba(255,255,255,0.30)", fontSize: 12 }} axisLine={false} tickLine={false} />
                <Tooltip
                  contentStyle={{ background: "#0a0820", border: "1px solid rgba(139,92,246,0.40)", borderRadius: 12, fontSize: 13, color: "#fff" }}
                  cursor={{ stroke: "rgba(167,139,250,0.30)", strokeWidth: 1 }}
                  formatter={(v) => [`${v}`, "Readiness"]}
                />
                <Area
                  dataKey="score" stroke="#a78bfa" strokeWidth={2.5}
                  fill="url(#aiDashAreaGrad)"
                  dot={{ fill: "#a78bfa", r: 4, strokeWidth: 0 }}
                  activeDot={{ r: 6, fill: "#c4b5fd", strokeWidth: 0 }}
                />
              </AreaChart>
            </ResponsiveContainer>
          </div>

          {/* Action Center */}
          <div
            ref={ref(7)}
            className="rounded-2xl p-7"
            style={{
              background: "linear-gradient(180deg, rgba(15,10,35,0.68) 0%, rgba(7,10,22,0.82) 100%)",
              border: "1px solid rgba(255,255,255,0.07)",
            }}
          >
            <h2 className="mb-6 text-xl font-black text-white">Action Center</h2>
            <div className="grid grid-cols-1 gap-4 sm:grid-cols-3">
              {[
                {
                  icon: Play, label: "Start New Session", desc: "Begin a fresh AI counselling session",
                  cardStyle: { background: "linear-gradient(135deg, rgba(37,99,235,0.24) 0%, rgba(67,56,202,0.24) 100%)", border: "1px solid rgba(59,130,246,0.30)" },
                  text: "text-blue-300",
                },
                {
                  icon: RotateCcw, label: "Retake Assessment", desc: "Get an updated readiness evaluation",
                  cardStyle: { background: "linear-gradient(135deg, rgba(124,58,237,0.24) 0%, rgba(109,40,217,0.24) 100%)", border: "1px solid rgba(139,92,246,0.30)" },
                  text: "text-violet-300",
                },
                {
                  icon: Settings, label: "Update Info", desc: "Edit your profile and preferences",
                  cardStyle: { background: "linear-gradient(135deg, rgba(51,65,85,0.30) 0%, rgba(30,41,59,0.30) 100%)", border: "1px solid rgba(100,116,139,0.28)" },
                  text: "text-slate-300",
                },
              ].map(({ icon: Icon, label, desc, cardStyle, text }) => (
                <button
                  key={label}
                  className="group flex flex-col gap-4 rounded-2xl p-6 text-left transition-all duration-200 hover:scale-[1.02] hover:brightness-110"
                  style={cardStyle}
                >
                  <div className="flex h-11 w-11 items-center justify-center rounded-xl" style={{ background: "rgba(255,255,255,0.09)" }}>
                    <Icon className={`h-5 w-5 ${text}`} />
                  </div>
                  <div>
                    <p className={`text-base font-black ${text}`}>{label}</p>
                    <p className="mt-0.5 text-sm text-white/35">{desc}</p>
                  </div>
                </button>
              ))}
            </div>
          </div>

          <div className="h-10" />
        </div>
      </div>
    </div>,
    document.body,
  );
}
