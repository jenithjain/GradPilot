        ? { background: "linear-gradient(135deg, rgba(136,19,55,0.30) 0%, rgba(159,18,57,0.24) 100%)", border: "1px solid rgba(244,63,94,0.28)" }
        : { background: "linear-gradient(135deg, rgba(5,78,59,0.30) 0%, rgba(6,55,40,0.24) 100%)",    border: "1px solid rgba(16,185,129,0.28)" },
